<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="4dp"
        android:paddingVertical="8dp"
        android:background="@color/purple_light"
        android:gravity="center_vertical"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/text_primary"
            android:contentDescription="Back to message" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Upload to Social"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center" />

        <View android:layout_width="48dp" android:layout_height="48dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Platform"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <LinearLayout
                        android:id="@+id/tileBlogger"
                        android:layout_width="0dp"
                        android:layout_height="85dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_platform_tile"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="8dp">
                        <ImageView android:layout_width="28dp" android:layout_height="28dp"
                            android:src="@drawable/ic_rss_feed" app:tint="@color/purple_primary"
                            android:contentDescription="Blogger" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Blogger" android:textSize="12sp" android:textStyle="bold"
                            android:textColor="@color/text_primary" android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/tileTwitter"
                        android:layout_width="0dp"
                        android:layout_height="85dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_platform_tile"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="8dp">
                        <ImageView android:layout_width="28dp" android:layout_height="28dp"
                            android:src="@drawable/ic_twitter" app:tint="@color/purple_primary"
                            android:contentDescription="Twitter" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Twitter" android:textSize="12sp" android:textStyle="bold"
                            android:textColor="@color/text_primary" android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/tileImgur"
                        android:layout_width="0dp"
                        android:layout_height="85dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_platform_tile"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="8dp">
                        <ImageView android:layout_width="28dp" android:layout_height="28dp"
                            android:src="@drawable/ic_image" app:tint="@color/purple_primary"
                            android:contentDescription="Imgur" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Imgur" android:textSize="12sp" android:textStyle="bold"
                            android:textColor="@color/text_primary" android:layout_marginTop="4dp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/tileTumblr"
                        android:layout_width="0dp"
                        android:layout_height="85dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_platform_tile"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="8dp">
                        <ImageView android:layout_width="28dp" android:layout_height="28dp"
                            android:src="@drawable/ic_format_bold" app:tint="@color/purple_primary"
                            android:contentDescription="Tumblr" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Tumblr" android:textSize="12sp" android:textStyle="bold"
                            android:textColor="@color/text_primary" android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/tileFacebook"
                        android:layout_width="0dp"
                        android:layout_height="85dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_platform_tile"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="8dp">
                        <ImageView android:layout_width="28dp" android:layout_height="28dp"
                            android:src="@drawable/ic_social" app:tint="@color/purple_primary"
                            android:contentDescription="Facebook" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Facebook" android:textSize="12sp" android:textStyle="bold"
                            android:textColor="@color/text_primary" android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/tileMedium"
                        android:layout_width="0dp"
                        android:layout_height="85dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_platform_tile"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="8dp">
                        <ImageView android:layout_width="28dp" android:layout_height="28dp"
                            android:src="@drawable/ic_article" app:tint="@color/purple_primary"
                            android:contentDescription="Medium" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Medium" android:textSize="12sp" android:textStyle="bold"
                            android:textColor="@color/text_primary" android:layout_marginTop="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/purple_light"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_circle_purple_light">
                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_person"
                            app:tint="@color/purple_primary"
                            android:contentDescription="User profile" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvConnectedAs"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Connected to Twitter"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:paddingStart="12dp"
                        tools:ignore="RtlSymmetry" />

                    <Button
                        android:id="@+id/btnSwitchAccount"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="Switch"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:backgroundTint="@android:color/white"
                        app:cornerRadius="8dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Post Preview"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="10dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/tvPreviewTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="6dp"
                        tools:text="Preview Title" />

                    <TextView
                        android:id="@+id/tvPreviewBody"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:lineSpacingMultiplier="1.4"
                        android:layout_marginBottom="8dp"
                        tools:text="This is what your post will look like on social media..." />

                    <TextView
                        android:id="@+id/tvCharCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:text="0/280"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/purple_primary" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@android:color/white"
        android:elevation="8dp">

        <Button
            android:id="@+id/btnUploadNow"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Upload Now"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/purple_primary"
            android:drawableStart="@drawable/ic_cloud_upload"
            app:drawableTint="@android:color/white"
            android:drawablePadding="8dp"
            app:cornerRadius="12dp" />
    </LinearLayout>

</LinearLayout>